{
  "name": "@aquascape/ui",
  "version": "0.1.0",
  "description": "Aquascape-studio shared React primitives — ink-green design system",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./theme": { "types": "./dist/theme/index.d.ts", "import": "./dist/theme/index.js" },
    "./theme/tokens": { "types": "./dist/theme/tokens.d.ts", "import": "./dist/theme/tokens.js" },
    "./theme/css": { "types": "./dist/theme/css.d.ts", "import": "./dist/theme/css.js" },
    "./theme/tailwind": { "types": "./dist/theme/tailwind.d.ts", "import": "./dist/theme/tailwind.js" },
    "./primitives": { "types": "./dist/primitives/index.d.ts", "import": "./dist/primitives/index.js" },
    "./patterns": { "types": "./dist/patterns/index.d.ts", "import": "./dist/patterns/index.js" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'ui lint placeholder'",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "react-native": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "packageManager": "pnpm@9.12.0"
}
