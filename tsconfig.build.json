{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true
  },
  "include": [
    "index.ts",
    "theme/**/*.ts",
    "theme/**/*.tsx",
    "primitives/**/*.ts",
    "primitives/**/*.tsx",
    "patterns/**/*.ts",
    "patterns/**/*.tsx"
  ],
  "exclude": ["**/*.stories.tsx", "**/*.test.ts", "**/*.test.tsx"]
}
